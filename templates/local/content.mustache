{{!
    @template format_grid/local/content

    Grid format main content template.

    Context variables required for this template:
    * title - The course title
    * sections - Array of section objects
    * gridcolumns - Number of grid columns
    * gridclass - Bootstrap row-cols utility classes (e.g. "row-cols-1 row-cols-sm-2 row-cols-lg-3")
    * cardstyle - Card display style
    * aspectclass - Aspect ratio class

    Example context (json):
    {
        "title": "Course Title",
        "gridcolumns": 3,
        "gridclass": "row-cols-1 row-cols-sm-2 row-cols-lg-3",
        "cardstyle": "card",
        "sections": []
    }
}}
<style>
[data-region="format-grid"] {
    --format-grid-badge-bg: {{completebadgebg}};
    --format-grid-badge-text: {{completebadgetext}};
    --format-grid-progress-color: {{progressbarcolor}};
    --format-grid-not-started-color: {{notstartedcolor}};
    --format-grid-in-progress-color: {{inprogresscolor}};
    --format-grid-complete-color: {{completecolor}};
}
</style>
<div class="format-grid-content" data-region="format-grid">
    {{! Section 0 - General section displayed above grid (default mode only) }}
    {{#section0asdefault}}
        {{#initialsection}}
            <div class="format-grid-section0">
                {{{initialsection}}}
            </div>
        {{/initialsection}}
    {{/section0asdefault}}

    {{! Single section view - shows full section with activities }}
    {{#singlesection}}
        <div class="format-grid-single-section">
            {{> core_courseformat/local/content/section }}
        </div>
        {{#sectionnavigation}}
            {{> core_courseformat/local/content/sectionnavigation }}
        {{/sectionnavigation}}
        {{#sectionselector}}
            {{> core_courseformat/local/content/sectionselector }}
        {{/sectionselector}}
    {{/singlesection}}

    {{! Grid view - all sections as cards }}
    {{^singlesection}}
        <ul class="format-grid-cards row {{gridclass}} {{aspectclass}} g-4 mx-0 list-unstyled section-list" data-cardstyle="{{cardstyle}}" data-for="course_sectionlist">
            {{#sections}}
                {{! Show section 0 as card only if section0ascard is true }}
                {{#issection0}}
                    {{#section0ascard}}
                        {{> format_grid/local/content/section }}
                    {{/section0ascard}}
                {{/issection0}}
                {{^issection0}}
                    {{> format_grid/local/content/section }}
                {{/issection0}}
            {{/sections}}
        </ul>

        {{! Add section button (editing mode) }}
        {{#numsections}}
            <div class="format-grid-add-section">
                {{> core_courseformat/local/content/addsection }}
            </div>
        {{/numsections}}
    {{/singlesection}}

    {{! Bulk edit tools }}
    {{#bulkedittools}}
        {{> core_courseformat/local/content/bulkedittools }}
    {{/bulkedittools}}
</div>
{{#js}}
require(['core_courseformat/local/content'], function(component) {
    component.init(
        '[data-region="format-grid"]', {}, {{sectionreturn}}, {{#pagesectionid}}{{.}}{{/pagesectionid}}{{^pagesectionid}}null{{/pagesectionid}}
    );
});
{{/js}}
